{
  "name": "baseaccess",
  "version": "1.0.0",
  "description": "Gestión de Expedientes con Historial - Desktop App",
  "author": {
    "name": "baseaccess",
    "email": "baseaccess@example.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder build --win dir --x64",
    "build:linux": "electron-builder build --linux"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.baseaccess.expedientes",
    "productName": "GestionExpedientes",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "vendor",
        "to": "vendor"
      }
    ],
    "win": {
      "target": [
        "dir"
      ],
      "icon": null
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": null,
      "category": "Office"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.3.0"
  }
}
